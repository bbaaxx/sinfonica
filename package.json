{
  "name": "sinfonica",
  "version": "0.1.0",
  "description": "Sinfonica CLI scaffold",
  "type": "module",
  "main": "dist/cli/index.js",
  "types": "dist/cli/index.d.ts",
  "bin": {
    "sinfonica": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/sync-cli-entrypoints.mjs",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "check:core": "npm run build && npm test",
    "check:surface:pi": "npm run build --prefix surfaces/pi && npm test -- surfaces/pi/tests",
    "check:surface:opencode": "npm run build --prefix surfaces/opencode && npm test -- surfaces/opencode/tests",
    "check:matrix:p4": "npm run check:core && npm run check:surface:pi && npm run check:surface:opencode",
    "check:smoke:install:pi": "node scripts/install-smoke.mjs surfaces/pi",
    "check:smoke:install:opencode": "node scripts/install-smoke.mjs surfaces/opencode",
    "check:entrypoints": "node scripts/check-entrypoints.mjs",
    "check:entrypoints:clean": "node scripts/check-entrypoints.mjs --clean-build",
    "prepare": "npm run build",
    "prepublishOnly": "npm test && npm run check:entrypoints:clean"
  },
  "files": [
    "dist/",
    "agents/",
    "commands/",
    "skills/",
    "plugins/",
    "workflows/",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bbaaxx/sinfonica.git"
  },
  "keywords": [
    "opencode",
    "ai",
    "agent",
    "workflow",
    "orchestration",
    "mcp"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@sinclair/typebox": "^0.34.48",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  },
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "author": "",
  "bugs": {
    "url": "https://github.com/bbaaxx/sinfonica/issues"
  },
  "homepage": "https://github.com/bbaaxx/sinfonica#readme"
}
